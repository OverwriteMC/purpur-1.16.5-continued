From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Github Actions <artyom030803@gmail.com>
Date: Thu, 9 Jul 2026 14:54:16 +0300
Subject: [PATCH] Backport Paper void damage fix


diff --git a/src/main/java/net/minecraft/world/entity/Entity.java b/src/main/java/net/minecraft/world/entity/Entity.java
index 139c69f92addd4f886e09997e4a77f445528a588..68c162a5620a14fd29101e7d1c3e9bebe2eb8978 100644
--- a/src/main/java/net/minecraft/world/entity/Entity.java
+++ b/src/main/java/net/minecraft/world/entity/Entity.java
@@ -123,6 +123,7 @@ import org.bukkit.craftbukkit.event.CraftPortalEvent;
 import org.bukkit.entity.Hanging;
 import org.bukkit.entity.LivingEntity;
 import org.bukkit.entity.Vehicle;
+import org.bukkit.entity.Player;
 import org.bukkit.event.entity.EntityCombustByEntityEvent;
 import org.bukkit.event.hanging.HangingBreakByEntityEvent;
 import org.bukkit.event.vehicle.VehicleBlockCollisionEvent;
@@ -748,10 +749,21 @@ public abstract class Entity implements INamableTileEntity, ICommandListener, ne
 
     // Paper start
     protected void performVoidDamage() {
-        if (this.locY() < world.purpurConfig.voidDamageHeight || (this.world.getWorld().getEnvironment() == org.bukkit.World.Environment.NETHER // Purpur
-            && world.paperConfig.doNetherTopVoidDamage()
-            && this.locY() >= world.paperConfig.netherVoidTopDamageHeight)) {
+        // Paper - creative and spectator players are invulnerable to nether ceiling damage
+        if (this.locY() < world.purpurConfig.voidDamageHeight) {
             this.doVoidDamage();
+            return;
+        }
+
+        boolean netherTopVoidDamage = this.world.getWorld().getEnvironment() == org.bukkit.World.Environment.NETHER // Purpur
+            && world.paperConfig.doNetherTopVoidDamage()
+            && this.locY() >= world.paperConfig.netherVoidTopDamageHeight;
+        if (netherTopVoidDamage) {
+            CraftEntity bukkitEntity = this.getBukkitEntity();
+            boolean invulnerablePlayer = bukkitEntity instanceof Player && ((Player) bukkitEntity).isInvulnerable();
+            if (!invulnerablePlayer) {
+                this.doVoidDamage();
+            }
         }
     }
     // Paper end
